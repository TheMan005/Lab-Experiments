%{
#include "decision.tab.h" // Generated by Bison
%}

%%

"if"        { return IF; }
"else"      { return ELSE; }

[a-zA-Z_][a-zA-Z0-9_]* { return ID; }
[0-9]+                 { return NUMBER; }

">"|"<"|">="|"<="|"=="|"!=" { return RELOP; }

[ \t\n]+    { /* Ignore whitespace and newlines */ }

.           { return yytext[0]; /* Return any other character like (, ), {, }, =, ; */ }

%%

int yywrap() {
    return 1;
}

